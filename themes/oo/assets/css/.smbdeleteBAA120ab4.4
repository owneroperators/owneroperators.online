@font-face {
  font-family: "MgOpenModerna";
  src: url("https://cdn.pinecone.website/fonts/MgOpenModernaRegular.ttf") format("truetype");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: "MgOpenModerna";
  src: url("https://cdn.pinecone.website/fonts/MgOpenModernaBold.ttf") format("truetype");
  font-weight: 700;
  font-style: normal;
  font-display: swap;
}

:root {
  --bg: #0a0a0a;
  --fg: #f2f1ed;
  --muted: #8a8a8a;
  --accent: #f2f1ed;
  --rule: #1f1f1f;
  --max: 64rem;
  --font-display: ui-sans-serif, system-ui, -apple-system, "Helvetica Neue", Arial, sans-serif;
  --font-body: "MgOpenModerna", ui-sans-serif, system-ui, -apple-system, "Helvetica Neue", Arial, sans-serif;
}

* { box-sizing: border-box; }

html, body {
  margin: 0;
  padding: 0;
  background: var(--bg);
  color: var(--fg);
  font-family: var(--font-body);
  font-size: 16px;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
}

body {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

a {
  color: var(--fg);
  text-decoration: underline;
  text-underline-offset: 0.2em;
  text-decoration-thickness: 1px;
}
a:hover { text-decoration-thickness: 2px; }

main {
  flex: 1 0 auto;
  width: 100%;
  max-width: var(--max);
  margin: 0 auto;
  padding: 4rem 1.5rem 6rem;
}

.hero {
  padding: 2rem 0 3rem;
  border-bottom: 1px solid var(--rule);
  margin-bottom: 3rem;
}

.brand {
  font-family: var(--font-display);
  font-weight: 800;
  font-size: clamp(2.5rem, 9vw, 6rem);
  letter-spacing: -0.02em;
  line-height: 0.95;
  margin: 0;
  text-transform: uppercase;
}
.brand .slash {
  color: var(--muted);
  margin: 0 0.05em;
  font-weight: 500;
}

.eyebrow {
  font-family: var(--font-body);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-size: 0.78rem;
  color: var(--muted);
  margin: 0 0 0.75rem;
}

.release { margin: 0 0 4rem; }
.release-title {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 4vw, 2.25rem);
  font-weight: 700;
  margin: 0 0 0.25rem;
  letter-spacing: -0.01em;
}
.release-from {
  color: var(--muted);
  margin: 0 0 1.5rem;
}

.dsp-links {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 1rem 2rem;
}
.dsp-pending {
  color: var(--muted);
  font-style: italic;
}

.intro { max-width: 48rem; }
.intro p { margin: 0 0 1em; }

.prose { max-width: 48rem; }
.prose h2, .prose h3 { font-family: var(--font-display); }
.prose a { color: var(--fg); }

.list {
  list-style: none;
  padding: 0;
  margin: 2rem 0;
}
.list li { padding: 0.5rem 0; border-bottom: 1px solid var(--rule); }

footer {
  max-width: var(--max);
  margin: 0 auto;
  padding: 2rem 1.5rem 3rem;
  color: var(--muted);
  font-size: 0.85rem;
  border-top: 1px solid var(--rule);
}

@media (prefers-reduced-motion: no-preference) {
  a { transition: text-decoration-thickness 0.15s ease; }
}
