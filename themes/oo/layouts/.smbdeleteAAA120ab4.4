{{ define "main" }}
<section class="hero">
  <h1 class="brand"><span class="brand-a">OWNER</span><span class="slash">/</span><span class="brand-b">OPERATORS</span></h1>
</section>

{{ with site.Params.release }}
<section class="release">
  <p class="eyebrow">First single{{ with .releaseDate }} — {{ dateFormat "January 2, 2006" . }}{{ end }}</p>
  <h2 class="release-title">{{ .title }}</h2>
  {{ with .from }}<p class="release-from">from <em>{{ . }}</em></p>{{ end }}
  {{ partial "dsp-links.html" . }}
</section>
{{ end }}

<section class="intro">
  {{ .Content }}
</section>
{{ end }}
